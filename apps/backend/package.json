{
  "name": "fitness-tracker-backend",
  "description": "Fitness tracker backend",
  "version": "0.5.17",
  "author": "Alexandr Dergunov <dergunovs@mail.ru> (https://github.com/dergunovs)",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dergunovs/fit.git",
    "directory": "apps/backend"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "build": "esbuild src/index.ts --platform=node --outdir=dist --format=esm --bundle --minify --legal-comments=none --banner:js='import{createRequire as __cr}from\"node:module\";import{fileURLToPath as __f}from\"node:url\";import{dirname as __d}from\"node:path\";if(typeof require===\"undefined\")globalThis.require=__cr(import.meta.url);const __filename=__f(import.meta.url);const __dirname=__d(__filename);'",
    "lint": "eslint src/**/*.{js,ts}",
    "ts": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "9.1.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "ajv": "8.18.0",
    "bcryptjs": "3.0.3",
    "fastify": "5.8.4",
    "fastify-plugin": "5.1.0",
    "fitness-tracker-contracts": "*",
    "mhz-helpers": "1.4.24",
    "mongoose": "9.4.1",
    "nodemailer": "8.0.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "25.5.2",
    "@types/nodemailer": "8.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "64.0.0",
    "fastify-linters-config": "0.3.3",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  },
  "engines": {
    "npm": ">=11.6.2",
    "node": ">=25.2.0"
  }
}
