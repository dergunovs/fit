// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`HelpPage > matches snapshot 1`] = `
"<div column="" gap="16">
  <h1>Помощь</h1>
  <div>
    <p>Исходный код: <a href="https://github.com/dergunovs/fit" target="_blank" rel="nofollow noreferrer noopener">Github</a></p>
    <p>Видео про разработку приложения: <a href="https://vkvideo.ru/playlist/15313879_11" target="_blank" rel="nofollow noreferrer noopener">VK</a>, <a href="https://youtube.com/playlist?list=PLOICX-WjKEZcaT9VXzntq0inHwTBQKXkr" target="_blank" rel="nofollow noreferrer noopener">Youtube</a></p>
    <p>Электронная почта для связи: mail@app-fit.ru</p>
  </div>
  <h3>Установка</h3>
  <div> RuStore(Android): <a href="https://www.rustore.ru/catalog/app/com.appfit.dev" target="_blank" rel="nofollow noreferrer noopener">Установка</a></div>
  <div>
    <p>Установка через браузер (Google Chrome, в iOS - Safari):</p>
    <p>Android: зайдите на app-fit.ru, войдите в меню браузера ⋮ и выберите 'Добавить на главный экран'.</p>
    <p>iOS: зайдите на app-fit.ru, нажмите иконку 'Поделиться' и выберите 'Добавить на главный экран'.</p>
    <p>PC: зайдите на app-fit.ru, в адресной строке нажмите кнопку 'Установить'.</p>
  </div>
  <h3>Регистрация</h3>
  <div>
    <p>Зарегистрируйтесь, перейдите по ссылке подтверждения в письме на почте. Проверьте спам, если письма нет.</p>
    <p>В профиле добавьте своё оборудование - от этого зависит список доступных упражнений. У некоторого оборудования есть выбор веса. Например, гантели 2 и 3 кг. Если у вас несколько весов, то появится выбор веса по-умолчанию. В профиле можно добавить до 20 своих упражнений, установить недельные цели по тренировкам, создать шаблоны тренировок.</p>
  </div>
  <h3>Прохождение занятия</h3>
  <div>
    <p>Добавьте упражнения. Укажите количество повторов и вес. Есть фильтры по группам мышц и названию упражнений. Можно добавлять сразу по 2 или 3 подхода. Если два последних упражнения отличаются, то появится кнопка добавление сета из них.</p>
    <p>Используйте шаблоны для быстрого создания занятий: они создаются в профиле и при формировании занятия. Можно преобразовать в шаблон прошедшие занятия из календаря во всплывающем окне.</p>
    <p>Можно начать занятие сразу или добавить в календарь: нажмите на кнопку 'Календарь' при создании занятия. Выберите дату и нажмите кнопку 'Сохранить занятие в календаре'. Затем в календаре выберите будущее занятие и нажмите кнопку 'Начать'.</p>
    <p>Затем нажмите 'Начать' на экране прохождения занятия, чтобы запустить таймер первого упражнения. Если подход выполнен до отказа, то отметьте это. В процессе прохождения занятия можно редакторировать упражнения. После окончания упражнения нажмите кнопку 'Завершить'.</p>
    <p>Выполненное занятие в календаре окрашивается в цвет задействованных групп мышц.</p>
    <p>Таймер позволяет прогнозировать время будущих занятий, отслеживать среднее время отдыха, наглядно отображать занятие в статистике.</p>
  </div>
  <user-feedback-form-stub></user-feedback-form-stub>
</div>"
`;
