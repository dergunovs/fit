// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ExerciseInfo > matches snapshot 1`] = `
"<div column="" gap="16">
  <div column="">
    <h3 data-test="exercise-info-title">Отжимание от скамьи</h3>
    <!--v-if-->
    <div>
      <div>Мышцы</div>
      <div>
        <div data-test="exercise-info-muscle" style="border-bottom-width: 3px; border-bottom-style: solid; border-bottom-color: #00CED1;">Грудь</div>
        <div data-test="exercise-info-muscle" style="border-bottom-width: 3px; border-bottom-style: solid; border-bottom-color: #0000ff;">Ноги</div>
      </div>
    </div>
    <div data-test="exercise-info-equipment">
      <div>Необходимо оборудование</div>
      <div>
        <div data-test="exercise-info-equipment-title">Скамья</div>
      </div>
    </div>
    <div data-test="exercise-info-is-weights">
      <div><span>Оборудование для веса</span><span data-test="exercise-info-is-weights-required"><b> (обязательно)</b></span></div>
      <div>
        <div data-test="exercise-info-equipment-for-weight">Гантели</div>
      </div>
    </div>
  </div>
  <!--v-if-->
  <div data-test="exercise-info-description">Описание 1</div>
</div>"
`;
